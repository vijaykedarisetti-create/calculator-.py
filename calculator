while True:
    print("1.Add\n2.Subtract\n3.Multiply\n4.Divide\n5.Exit")
    ch = input("Choice: ")

    if ch == "5":
        break

    a = float(input("Enter first number: "))
    b = float(input("Enter second number: "))

    if ch == "1":
        print("Result:", a+b)
    elif ch == "2":
        print("Result:", a-b)
    elif ch == "3":
        print("Result:", a*b)
    elif ch == "4":
        print("Result:", a/b)
